# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=""

# OpenAI API Key
OPENAI_API_KEY=""

# Anthropic API Key
ANTHROPIC_API_KEY=""

# Mistral API Key
MISTRAL_API_KEY=""

# Groq API Key
GROQ_API_KEY=""

# OpenRouter API Key
OPENROUTER_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"
